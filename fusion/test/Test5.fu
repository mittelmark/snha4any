public class Rand {
	/// Initialize the random number generator.
	/// Will have same output with the same seed all the time.
	long RandomState = 1;
	public void Seed! (
		/// Initialize the random numbers with a specific value.
		long x) {
		RandomState = x;
	}
	/// Initialize the random number generator.
	/// Will have different output with every run.
	public void SeedNow! () {
		RandomState = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

	}
	/// private function - returns bitshift by the given n of 1.
	static long LowBits(
		/// integer value bitshift returned.
		int n
	) {
		long one = 1;
		return (one << n) - 1;
	}
	/// Create a random number using the xorshift algorithm.
	public float NextRandom!()
	{
      float f = 0.0;

    #if SWIFT
	native {
		var state: Int64 = self.randomState
		
		state ^= state >> 12 & Int64(Rand.lowBits(52))
		state ^= (state & Int64(Rand.lowBits(39))) << 25
		state ^= state >> 27 & Int64(Rand.lowBits(37))
		self.randomState = state
		
		let a = UInt64(bitPattern: state)
		let m: UInt64 = 2685821657736338717
		
		// full 128-bit product split into high/low 64-bit parts
		let product = a.multipliedFullWidth(by: m) // (high: UInt64, low: UInt64)
		
		// Equivalent to: (state * m) >> 40
		let shifted = UInt64(truncatingIfNeeded: (product.high << (64 - 40)) | (product.low >> 40))
		
		let bits = shifted & UInt64(Rand.lowBits(24))
		f = Float(bits)
		//return Float(bits) / 16777216.0
	}
	#else
		// https://en.wikipedia.org/wiki/Xorshift#xorshift.2A
		long state = RandomState;
		state ^= state >> 12 & LowBits(52);
		state ^= (state & LowBits(39)) << 25;
		state ^= state >> 27 & LowBits(37);
		RandomState = state;
		f = (state * 0x2545f4914f6cdd1d >> 40) & LowBits(24);
	#endif
		return f / 16777216.0;
    }
	public static void Run (string[] args) {
		Rand() rnd;
		rnd.Seed(123);
		for (int i = 0; i < 10; i++) {
			float r = rnd.NextRandom();
			Console.WriteLine($"On position {i} the random value is {r}!");
		}
	}
    
	public static void Main(string[] args) {
		Rand.Run(args);
	}
}

