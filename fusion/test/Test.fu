
public static class Test {
	public static List<int>() GetVector() {
		List<int>() x;
		x.Add(1);
		x.Add(2);
		return(x);
	}
	public static void Main(string[] args) {
		List<int>   y = Test.GetVector();
		List<int>() z = Test.GetVector();
		for (int i = 0; i<y.Count; i++) {
			Console.WriteLine($"y[{i}] = {y[i]}");
			Console.WriteLine($"z[{i}] = {z[i]}");			
		}
	}
}

