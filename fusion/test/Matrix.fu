public class Matrix {
	List<List<float>()>() M;
	int nc = 0;
	int nr = 0;

	// constructors can't take arguments so we do a create function
	public void Create! (int nrow, int ncol, float value=0) {
		for (int i = 0; i < nrow; i++) {
			M.Add();
			for (int j = 0; j < ncol; j++) {
				M[i].Add(value);
			}
		}
		nc = ncol;
		nr = nrow;
	}

	// exclamation mark as object is modified
	public void Set!(int row, int col, float value) {
		M[row][col] = value;
	}

	public float Get(int row, int col) {
		return(M[row][col]);
	}

	public List<float>() GetRow(int row) {
		return(M[row]);
	}

	public List<float>() GetColumn(int col) {
		List<float>() values;
		for (int i = 0; i < nr; i++) {
			values.Add(M[i][col]);
		}
		return(values);
	}

	public int Nrow() => nr;
	public int Ncol() => nc;
	public static void PrintMatrix(Matrix N) {
		for (int i = 0; i < N.Nrow(); i++) {
			for (int j = 0; j < N.Ncol(); j++) {
				Console.Write($"{N.Get(i, j)}\t");
			}
			Console.WriteLine("");
		}
	}

	public static void Main(string[] args) {
		Console.WriteLine("\nTesting matrix");
		Matrix() M;
		M.Create(3, 3, 0);

		M.Set(0, 0, 1);
		M.Set(0, 1, 2);
		M.Set(0, 2, 3);

		M.Set(1, 0, 4);
		M.Set(1, 1, 5);
		M.Set(1, 2, 6);

		M.Set(2, 0, 7);
		M.Set(2, 1, 8);
		M.Set(2, 2, 9);

		Console.WriteLine("Original matrix:");
		Matrix.PrintMatrix(M);
		Matrix.PrintMatrix(M);
	}
}
