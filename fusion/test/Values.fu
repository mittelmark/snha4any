
public static class Values {
	 public static void AddValues (int n, FloatVector! vals) {
		 for (int i = 0; i < n; i++) {
			 float f = i*1.0;
			 vals.Add(f);
		 }
	 }
	 public static void Main () {
		 FloatVector() vals;
		 AddValues(5,vals);
		 AddValues(6,vals);
		 Console.WriteLine($"Count: {vals.Count}");
	 }
	 
 }

